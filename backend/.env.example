# Django Configuration
DJANGO_SECRET_KEY=insecure-dev-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# If ENV=local, it defaults to sqlite. For dev/prod, provide a Postgres connection URL:
# DATABASE_URL=postgres://user:password@hostname:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Security & CORS
AUTH_COOKIE_SECURE=False
AUTH_COOKIE_DOMAIN=localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Frontend URL for emails/redirects
FRONTEND_URL=http://localhost:3000

# Resend Email Configuration
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=Lets Keep Memories <no-reply@lifememories.app>

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_secret_key

# OpenAI (Whisper) Configuration
OPENAI_API_KEY=sk-your_openai_key

# Optional Limits
MAX_UPLOAD_VIDEO_SIZE_MB=200
MAX_UPLOAD_IMAGE_SIZE_MB=15
MAX_UPLOAD_AUDIO_SIZE_MB=50
